<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:background="@drawable/menu_bg"
    android:orientation="vertical"
    android:padding="0dp"
    android:elevation="20dp">

    <!-- Header with Gradient Look -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal"
        android:background="@drawable/header_bg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHETO ENGINE"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="20sp"
            android:letterSpacing="0.2"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VIRTUAL SANDBOX ACTIVE"
            android:textColor="#00E5FF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp"
            android:letterSpacing="0.1"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#1AFFFFFF"/>

    <!-- Content Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MAIN FEATURES"
            android:textColor="#55FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"/>

        <!-- Bank Shots -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Show Bank Shots"
                android:textColor="#E0FFFFFF"
                android:textSize="15sp"
                android:layout_centerVertical="true"/>
            <Switch
                android:id="@+id/switchBankShots"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:thumbTint="#00E5FF"
                android:trackTint="#3300E5FF"
                android:checked="true"/>
        </RelativeLayout>

        <!-- Cue Path -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cue Ball Path"
                android:textColor="#E0FFFFFF"
                android:textSize="15sp"
                android:layout_centerVertical="true"/>
            <Switch
                android:id="@+id/switchCueReflection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:thumbTint="#00E5FF"
                android:trackTint="#3300E5FF"
                android:checked="true"/>
        </RelativeLayout>

        <!-- Anti-Ban (Visual Only Toggle) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Anti-Ban Protection"
                android:textColor="#00E676"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>
            <Switch
                android:id="@+id/switchAntiBan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:thumbTint="#00E676"
                android:trackTint="#3300E676"
                android:checked="true"
                android:enabled="false"/>
        </RelativeLayout>

        <!-- Always Break -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Always Break"
                android:textColor="#FF8F00"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_centerVertical="true"/>
            <Switch
                android:id="@+id/switchAlwaysBreak"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:thumbTint="#FF8F00"
                android:trackTint="#33FF8F00"
                android:checked="false"/>
        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LINE OPACITY"
            android:textColor="#55FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <SeekBar
            android:id="@+id/seekBarOpacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="255"
            android:progress="180"
            android:progressTint="#00E5FF"
            android:thumbTint="#00E5FF"
            android:layout_marginHorizontal="-12dp"/>

    </LinearLayout>

    <!-- Bottom Button Section -->
    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="MINIMIZE TOOL"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:textSize="14sp"
        android:backgroundTint="#22FFFFFF"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:layout_margin="12dp"
        android:stateListAnimator="@null"
        style="@style/Widget.AppCompat.Button.Borderless"/>

</LinearLayout>
